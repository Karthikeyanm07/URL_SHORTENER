{
	"compilerOptions": {
		"ignoreDeprecations": "6.0",
		"target": "ES2020",
		"module": "commonjs",
		"lib": [
			"ES2020"
		],
		"outDir": "./dist",
		"rootDir": "./src",
		"strict": true,
		"noImplicitAny": true,
		"strictNullChecks": true,
		"noUnusedLocals": true,
		"noUnusedParameters": true,
		"noImplicitReturns": true,
		"esModuleInterop": true,
		"skipLibCheck": true,
		"forceConsistentCasingInFileNames": true,
		"resolveJsonModule": true,
		"baseUrl": ".",
		"paths": {
			"@/*": [
				"src/*"
			]
		},
		"types": [
			"jest",
			"node"
		]
	},
	"include": [
		"src/**/*",
		"prisma.config.ts"
	],
	"exclude": [
		"node_modules",
		"dist",
		"generated"
	]
}